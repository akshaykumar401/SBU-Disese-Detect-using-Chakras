{
  "rewrites": [
    {
      "source": "/apii/:path*",
      "destination": "https://throat-feature.onrender.com/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://throat-google.vercel.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
